; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Game Project"
run/main_scene="res://scenes/main/Main.tscn"
config/features=PackedStringArray("4.7")

[autoload]

Core="*res://systems/core/core.gd"
SaveManager="*res://systems/save/save_manager.gd"
AudioManager="*res://systems/audio/audio_manager.gd"
UIManager="*res://systems/ui/ui_manager.gd"
DamageManager="*res://systems/combat/damage_manager.gd"
ProjectileManager="*res://systems/projectiles/projectile_manager.gd"
EnemyManager="*res://systems/enemies/enemy_manager.gd"
RunManager="*res://systems/run/run_manager.gd"
World="*res://systems/world/world.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[input]

move_up={
"deadzone": 0.5,
